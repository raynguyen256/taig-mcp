# =============================================
# Taiga MCP Server — Environment Variables
# =============================================

# Required: Taiga instance base URL
TAIGA_BASE_URL=https://taiga.enosta.com/api/v1

# Required: Credentials for initial login and re-auth when token expires
TAIGA_USERNAME=your_username
TAIGA_PASSWORD=your_password

# Token persistence: path to store auth token on disk
# Default: ~/.taiga-mcp/config.json
# TAIGA_CONFIG_FILE=~/.taiga-mcp/config.json

# Seconds before token age triggers a refresh (default: 72000 = 20 hours)
# TAIGA_TOKEN_REFRESH_THRESHOLD=72000

# Override: skip config file and disk entirely, use this token directly
# Set this if you manage tokens externally
# TAIGA_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cache TTL in seconds for static data (statuses, types, members)
# Default: 300 (5 minutes)
# TAIGA_CACHE_TTL=300

# HTTP request timeout in milliseconds
# Default: 30000 (30 seconds)
# TAIGA_REQUEST_TIMEOUT=30000

# Max retry attempts for 429/5xx errors
# Default: 3
# TAIGA_MAX_RETRIES=3

# Log level: debug | info | warn | error
# Default: info
# TAIGA_LOG_LEVEL=info
